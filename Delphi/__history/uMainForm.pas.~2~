implementation

{$R *.dfm}

// ─────────────────────────────────────────────────────────────────────────────
//  HTTP HELPERS
// ─────────────────────────────────────────────────────────────────────────────

function TfrmMain.Get(const AEndpoint: string): TJSONValue;
var
  Http: THTTPClient;
  Resp: IHTTPResponse;
begin
  Result := nil;
  Http := THTTPClient.Create;
  try
    Http.ConnectionTimeout := 5000;
    Http.ResponseTimeout   := 30000;
    try
      Resp := Http.Get(FAPI + AEndpoint);
      if Resp.StatusCode = 200 then
        Result := TJSONObject.ParseJSONValue(Resp.ContentAsString(TEncoding.UTF8));
    except
      // silencia: retorna nil
    end;
  finally
    Http.Free;
  end;
end;

function TfrmMain.Post(const AEndpoint: string; ABody: TJSONObject): TJSONValue;
var
  Http:    THTTPClient;
  Resp:    IHTTPResponse;
  Stream:  TStringStream;
begin
  Result := nil;
  Http   := THTTPClient.Create;
  Stream := TStringStream.Create(ABody.ToJSON, TEncoding.UTF8);
  try
    Http.ConnectionTimeout := 5000;
    Http.ResponseTimeout   := 60000;
    try
      Resp := Http.Post(FAPI + AEndpoint, Stream, nil,
                        [TNameValuePair.Create('Content-Type', 'application/json')]);
      Result := TJSONObject.ParseJSONValue(Resp.ContentAsString(TEncoding.UTF8));
    except
    end;
  finally
    Stream.Free;
    Http.Free;
  end;
end;

function TfrmMain.PostMultipart(const AEndpoint, AFilePath: string): TJSONValue;
var
  Http:      THTTPClient;
  Resp:      IHTTPResponse;
  FormData:  TMultipartFormData;
begin
  Result   := nil;
  Http     := THTTPClient.Create;
  FormData := TMultipartFormData.Create;
  try
    Http.ConnectionTimeout := 5000;
    Http.ResponseTimeout   := 60000;
    try
      FormData.AddFile('file', AFilePath);
      Resp := Http.Post(FAPI + AEndpoint, FormData);
      Result := TJSONObject.ParseJSONValue(Resp.ContentAsString(TEncoding.UTF8));
    except
    end;
  finally
    FormData.Free;
    Http.Free;
  end;
end;

procedure TfrmMain.Delete(const AEndpoint: string);
var
  Http: THTTPClient;
begin
  Http := THTTPClient.Create;
  try
    Http.ConnectionTimeout := 5000;
    Http.ResponseTimeout   := 15000;
    try
      Http.Delete(FAPI + AEndpoint);
    except
    end;
  finally
    Http.Free;
  end;
end;

