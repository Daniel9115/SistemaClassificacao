procedure TfrmMain.MostrarMsgCat(const AMsg: string; AErro: Boolean);
begin
  lblMsgCat.Caption    := AMsg;
  lblMsgCat.Font.Color := IfThen(AErro, clRed, clGreen);
  lblMsgCat.Visible    := True;
end;

procedure TfrmMain.CarregarCategorias;
var
  JSON:    TJSONValue;
  Arr:     TJSONArray;
  Cat:     TJSONValue;
  Node:    TTreeNode;
  SubNode: TTreeNode;
  Itens:   TJSONArray;
  Fotos:   TJSONArray;
  It:      TJSONValue;
  F:       TJSONValue;
  Nome:    string;
  Total:   Integer;
begin
  tvCategorias.Items.Clear;
  cboCatFoto.Items.Clear;

  JSON := Get('/categorias');
  if JSON = nil then Exit;

  try
    Arr := JSON as TJSONArray;
    for Cat in Arr do
    begin
      Nome  := Cat.GetValue<string>('nome');
      Total := Cat.GetValue<Integer>('total', 0);

      Node := tvCategorias.Items.Add(nil,
               Format('%s  (%d foto(s))', [Nome, Total]));
      Node.Data := TObject(Pointer(PChar(Nome)));  // guarda nome

      cboCatFoto.Items.Add(Nome);

      // subitens
      Itens := Cat.FindValue('itens') as TJSONArray;
      if Assigned(Itens) then
        for It in Itens do
        begin
          SubNode := tvCategorias.Items.AddChild(Node,
            Format('📁 %s  (%d)',
              [It.GetValue<string>('nome'),
               It.GetValue<Integer>('total', 0)]));
          SubNode.ImageIndex := 1;
        end;

      // fotos diretas
      Fotos := Cat.FindValue('fotos') as TJSONArray;
      if Assigned(Fotos) then
        for F in Fotos do
          tvCategorias.Items.AddChild(Node, '📷 ' + F.Value);

      Node.Expand(False);
    end;
  finally
    JSON.Free;
  end;
end;

procedure TfrmMain.btnAtualizarCatClick(Sender: TObject);
begin
  CarregarCategorias;
end;

procedure TfrmMain.btnCriarCatClick(Sender: TObject);
var
  Nome: string;
  Body: TJSONObject;
  JSON: TJSONValue;
begin
  Nome := Trim(edtNomeCat.Text);
  if Nome = '' then
  begin
    ShowMessage('Digite um nome para a categoria.');
    Exit;
  end;

  Body := TJSONObject.Create;
  try
    Body.AddPair('nome', Nome);
    JSON := Post('/categorias', Body);
  finally
    Body.Free;
  end;

  if Assigned(JSON) then
  begin
    JSON.Free;
    edtNomeCat.Clear;
    MostrarMsgCat('✓ Categoria "' + Nome + '" criada!');
    CarregarCategorias;
  end
  else
    MostrarMsgCat('Erro ao criar categoria.', True);
end;

procedure TfrmMain.btnRemoverCatClick(Sender: TObject);
var
  Node: TTreeNode;
  Nome: string;
  P:    Integer;
begin
  Node := tvCategorias.Selected;
  if Node = nil then
  begin
    ShowMessage('Selecione uma categoria na lista.');
    Exit;
  end;

  // pega o nó raiz (categoria pai)
  while Node.Parent <> nil do
    Node := Node.Parent;

  Nome := Node.Text;
  // remove o " (N foto(s))" do final
  P := Pos('  (', Nome);
  if P > 0 then
    Nome := Trim(Copy(Nome, 1, P - 1));

  if MessageDlg(Format('Excluir categoria "%s" e todas as fotos?', [Nome]),
                mtConfirmation, [mbYes, mbNo], 0) <> mrYes then Exit;

  Delete('/categorias/' + Nome);
  MostrarMsgCat('✓ Categoria "' + Nome + '" removida.');
  CarregarCategorias;
end;

procedure TfrmMain.btnBrowseFotoClick(Sender: TObject);
begin
  if dlgFoto.Execute then
    edtFotoPath.Text := dlgFoto.FileName;
end;

procedure TfrmMain.btnEnviarFotoClick(Sender: TObject);
var
  Cat:  string;
  Path: string;
  JSON: TJSONValue;
begin
  Cat  := cboCatFoto.Text;
  Path := Trim(edtFotoPath.Text);

  if Cat = '' then
  begin
    ShowMessage('Selecione uma categoria.');
    Exit;
  end;

  if Path = '' then
  begin
    ShowMessage('Selecione uma imagem.');
    Exit;
  end;

  if not FileExists(Path) then
  begin
    ShowMessage('Arquivo não encontrado: ' + Path);
    Exit;
  end;

  btnEnviarFoto.Enabled := False;
  btnEnviarFoto.Caption := 'Enviando...';
  Application.ProcessMessages;

  try
    JSON := PostMultipart('/categorias/' + Cat + '/fotos', Path);

    if Assigned(JSON) then
    begin
      JSON.Free;
      edtFotoPath.Clear;
      MostrarMsgCat('✓ Foto adicionada à categoria "' + Cat + '"!');
      CarregarCategorias;
    end
    else
      MostrarMsgCat('Erro ao enviar foto.', True);
  finally
    btnEnviarFoto.Enabled := True;
    btnEnviarFoto.Caption := 'Enviar Foto';
  end;
end;

