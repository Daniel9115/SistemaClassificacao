//  STATUS
// ─────────────────────────────────────────────────────────────────────────────

procedure TfrmMain.SetStatusOnline(AOnline, AModeloOk: Boolean; AClasses: Integer);
begin
  if not AOnline then
  begin
    shpStatus.Brush.Color := clRed;
    lblStatus.Caption     := 'API Offline';
    lblStatus.Font.Color  := clRed;
  end
  else if not AModeloOk then
  begin
    shpStatus.Brush.Color := $00CCAA00;
    lblStatus.Caption     := 'Conectada — sem modelo';
    lblStatus.Font.Color  := $00886600;
  end
  else
  begin
    shpStatus.Brush.Color := clGreen;
    lblStatus.Caption     := Format('Conectada — %d classe(s)', [AClasses]);
    lblStatus.Font.Color  := clGreen;
  end;
end;

procedure TfrmMain.AtualizarStatus;
var
  JSON:      TJSONValue;
  Online:    Boolean;
  ModeloOk:  Boolean;
  Classes:   TJSONArray;
  NClasses:  Integer;
begin
  JSON := Get('/status');
  if JSON = nil then
  begin
    SetStatusOnline(False, False, 0);
    Exit;
  end;
  try
    Online   := JSON.GetValue<Boolean>('online', False);
    ModeloOk := JSON.GetValue<Boolean>('modelo_carregado', False);
    NClasses := 0;
    Classes  := JSON.FindValue('classes') as TJSONArray;
    if Assigned(Classes) then
      NClasses := Classes.Count;
    SetStatusOnline(Online, ModeloOk, NClasses);
  finally
    JSON.Free;
  end;
end;

procedure TfrmMain.btnRefreshStatusClick(Sender: TObject);
begin
  AtualizarStatus;
end;

procedure TfrmMain.tmrStatusTimer(Sender: TObject);
begin
  AtualizarStatus;
end;

