    pnlBottom:     TPanel;

    // ── Header ────────────────────────────────────────────────
    lblTitulo:     TLabel;
    lblSubtitle:   TLabel;
    shpStatus:     TShape;
    lblStatus:     TLabel;
    btnRefreshStatus: TButton;

    // ── Abas ──────────────────────────────────────────────────
    pgc:           TPageControl;
    tabClassificar: TTabSheet;
    tabCategorias:  TTabSheet;
    tabTreinar:     TTabSheet;

    // ── Tab Classificar ───────────────────────────────────────
    pnlPreview:    TPanel;
    imgPreview:    TImage;
    lblDropHint:   TLabel;
    btnSelecionarImg: TButton;
    btnClassificar:   TButton;
    dlgAbrir:      TOpenDialog;

    pnlResultado:  TPanel;
    lblResClasse:  TLabel;
    lblResItem:    TLabel;
    lblResConf:    TLabel;
    lblResConfVal: TLabel;
    lblResClasseVal: TLabel;
    lblResItemVal:   TLabel;
    pbConfianca:   TProgressBar;

    mmoJSON:       TMemo;
    lblJSON:       TLabel;

    // ── Tab Categorias ────────────────────────────────────────
    grpCriarCat:   TGroupBox;
    edtNomeCat:    TEdit;
    btnCriarCat:   TButton;
    lblNomeCat:    TLabel;

    grpFoto:       TGroupBox;
    lblCatFoto:    TLabel;
    cboCatFoto:    TComboBox;
    lblFotoArq:    TLabel;
    edtFotoPath:   TEdit;
    btnBrowseFoto: TButton;
    btnEnviarFoto: TButton;
    dlgFoto:       TOpenDialog;

    grpBanco:      TGroupBox;
    tvCategorias:  TTreeView;
