procedure TfrmMain.Log(const AMsg: string);
begin
  mmoTreinoLog.Lines.Add(Format('[%s]  %s', [TimeToStr(Now), AMsg]));
  SendMessage(mmoTreinoLog.Handle, WM_VSCROLL, SB_BOTTOM, 0);
end;

procedure TfrmMain.btnTreinarClick(Sender: TObject);
var
  Body: TJSONObject;
  JSON: TJSONValue;
begin
  if FTreinando then
  begin
    ShowMessage('Treino já em andamento. Aguarde.');
    Exit;
  end;

  btnTreinar.Enabled      := False;
  btnTreinar.Caption      := 'Treinando...';
  pbTreino.Style          := TProgressBarStyle.pbstMarquee;
  pbTreino.MarqueeAnimationSpeed := 30;
  lblTreinoStatus.Caption := 'Iniciando treino...';
  FTreinando              := True;

  mmoTreinoLog.Clear;
  Log('Disparando POST /treinar ...');

  Body := TJSONObject.Create;
  try
    JSON := Post('/treinar', Body);
  finally
    Body.Free;
  end;

  if not Assigned(JSON) then
  begin
    pbTreino.Style          := TProgressBarStyle.pbstNormal;
    btnTreinar.Enabled      := True;
    btnTreinar.Caption      := 'Treinar Modelo';
    lblTreinoStatus.Caption := 'Erro: API não respondeu.';
    FTreinando              := False;
    Log('ERRO: sem resposta da API.');
    Exit;
  end;

  JSON.Free;
  Log('Treino em background iniciado. Aguardando conclusão...');

  // inicia polling
  tmrTreino.Enabled := True;
end;

procedure TfrmMain.tmrTreinoTimer(Sender: TObject);
var
  JSON:     TJSONValue;
  EmAnd:    Boolean;
  ModeloOk: Boolean;
  Classes:  TJSONArray;
  NClasses: Integer;
  C:        TJSONValue;
  Lista:    TStringList;
begin
  JSON := Get('/status');
  if JSON = nil then
  begin
    Log('Polling: sem resposta da API...');
    Exit;
  end;

  try
    EmAnd    := JSON.GetValue<Boolean>('treino_em_andamento', False);
    ModeloOk := JSON.GetValue<Boolean>('modelo_carregado', False);
    NClasses := 0;
    Classes  := JSON.FindValue('classes') as TJSONArray;
    if Assigned(Classes) then
      NClasses := Classes.Count;

    lblTreinoStatus.Caption :=
      Format('Treinando... (polling %s)', [TimeToStr(Now)]);

    if not EmAnd then
    begin
      // treino terminou
      tmrTreino.Enabled := False;
      FTreinando        := False;
      pbTreino.Style    := TProgressBarStyle.pbstNormal;
      pbTreino.Position := 100;
      btnTreinar.Enabled := True;
      btnTreinar.Caption := 'Treinar Modelo';

      if ModeloOk and (NClasses > 0) then
      begin
        lblTreinoStatus.Caption :=
          Format('✓ Treino concluído! %d classe(s) gerada(s).', [NClasses]);

        Lista := TStringList.Create;
        try
          if Assigned(Classes) then
            for C in Classes do
              Lista.Add('  • ' + C.Value);
          Log('Treino concluído com sucesso!');
          Log(Format('Classes (%d):', [NClasses]));
          Log(Lista.Text);
        finally
          Lista.Free;
        end;
      end
      else
      begin
        lblTreinoStatus.Caption := '⚠ Treino finalizado sem classes.';
        Log('AVISO: treino finalizou mas nenhuma classe foi gerada.');
        Log('Verifique se há imagens nas categorias do BancoImagens.');
      end;

      AtualizarStatus;
      CarregarCategorias;
    end;
  finally
    JSON.Free;
  end;
end;

// helper inline
function IfThen(ACondition: Boolean; const ATrue, AFalse: string): string;
begin
  if ACondition then Result := ATrue else Result := AFalse;
end;

end.
