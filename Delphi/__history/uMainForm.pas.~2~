procedure TfrmMain.btnSelecionarImgClick(Sender: TObject);
begin
  if not dlgAbrir.Execute then Exit;

  FImagemPath := dlgAbrir.FileName;

  try
    imgPreview.Picture.LoadFromFile(FImagemPath);
    imgPreview.Stretch  := True;
    imgPreview.Proportional := True;
    lblDropHint.Visible := False;
  except
    ShowMessage('Não foi possível carregar a imagem.');
    FImagemPath := '';
  end;
end;

procedure TfrmMain.imgPreviewDblClick(Sender: TObject);
begin
  btnSelecionarImgClick(Sender);
end;

procedure TfrmMain.MostrarResultado(AJSON: TJSONObject);
var
  Classe:    string;
  Item:      string;
  Confianca: Double;
  Indef:     Boolean;
  ConfPct:   Integer;
begin
  Classe    := AJSON.GetValue<string>('classe',    '');
  Item      := AJSON.GetValue<string>('item',      '');
  Confianca := AJSON.GetValue<Double>('confianca', 0);
  Indef     := AJSON.GetValue<Boolean>('indefinido', False);

  ConfPct := Round(Confianca * 100);

  if Indef or (Classe = '') then
  begin
    lblResClasseVal.Caption := 'Indefinido';
    lblResItemVal.Caption   := '-';
    lblResConfVal.Caption   := '0%';
    lblResClasseVal.Font.Color := clGray;
  end
  else
  begin
    lblResClasseVal.Caption    := UpperCase(Classe);
    lblResItemVal.Caption      := IfThen(Item <> '', Item, '-');
    lblResConfVal.Caption      := Format('%d%%', [ConfPct]);
    lblResClasseVal.Font.Color := clGreen;
  end;

  pbConfianca.Position := ConfPct;

  // barra muda de cor conforme confiança
  if ConfPct >= 75 then
    pbConfianca.State := TProgressBarState.pbsNormal
  else if ConfPct >= 50 then
    pbConfianca.State := TProgressBarState.pbsNormal
  else
    pbConfianca.State := TProgressBarState.pbsError;

  mmoJSON.Lines.Text := AJSON.Format(2);
end;

procedure TfrmMain.btnClassificarClick(Sender: TObject);
var
  JSON: TJSONValue;
begin
  if FImagemPath = '' then
  begin
    ShowMessage('Selecione uma imagem primeiro.');
    Exit;
  end;

  btnClassificar.Enabled  := False;
  btnClassificar.Caption  := 'Classificando...';
  lblResClasseVal.Caption := '...';
  lblResItemVal.Caption   := '...';
  lblResConfVal.Caption   := '...';
  Application.ProcessMessages;

  try
    JSON := PostMultipart('/classify', FImagemPath);

    if JSON = nil then
    begin
      ShowMessage('Erro ao conectar na API. Verifique se está rodando.');
      Exit;
    end;

    try
      // checa se veio detalhe de erro
      if JSON.FindValue('detail') <> nil then
      begin
        ShowMessage('API: ' + JSON.GetValue<string>('detail'));
        Exit;
      end;

      MostrarResultado(JSON as TJSONObject);
    finally
      JSON.Free;
    end;

  finally
    btnClassificar.Enabled := True;
    btnClassificar.Caption := 'Classificar';
  end;
end;

