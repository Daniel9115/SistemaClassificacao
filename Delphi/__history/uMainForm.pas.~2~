procedure TfrmMain.FormCreate(Sender: TObject);
begin
  FAPI       := 'http://localhost:8000';
  FTreinando := False;

  // timers
  tmrStatus.Interval := 5000;
  tmrStatus.Enabled  := True;
  tmrTreino.Interval := 2000;
  tmrTreino.Enabled  := False;

  // diálogos
  dlgAbrir.Filter  := 'Imagens|*.jpg;*.jpeg;*.png;*.bmp;*.webp';
  dlgFoto.Filter   := 'Imagens|*.jpg;*.jpeg;*.png;*.bmp;*.webp';

  AtualizarStatus;
  CarregarCategorias;
end;

procedure TfrmMain.FormDestroy(Sender: TObject);
begin
  tmrStatus.Enabled := False;
  tmrTreino.Enabled := False;
end;

