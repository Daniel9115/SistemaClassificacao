unit uMainForm;

{
  Classificador de Pratos — Delphi 12 VCL
  ─────────────────────────────────────────
  • Captura de câmera via DirectShow (sem libs externas)
  • Classificação assíncrona contra a API FastAPI (POST /classify)
  • UI equivalente ao frontend HTML original
}

interface

uses
  Winapi.Windows, Winapi.Messages, Winapi.ActiveX, Winapi.DirectShow9,
  System.SysUtils, System.Classes, System.Threading, System.JSON,
  System.Net.HttpClient, System.Net.Mime, System.Math,
  Vcl.Controls, Vcl.Forms, Vcl.ExtCtrls, Vcl.StdCtrls, Vcl.Graphics,
  Vcl.Imaging.jpeg;

const
  WM_CLASSIFY_DONE = WM_USER + 1;
  API_URL          = 'http://localhost:8000';
  INTERVALO_MS     = 1200;

  // ── Cores (BGR para TColor Delphi) ────────────────────────────────────────
  CL_BG         = TColor($00F7F2EE); // #eef2f7
  CL_CARD       = clWhite;
  CL_TEXT_DARK  = TColor($000F172A); // #0f172a
  CL_TEXT_MID   = TColor($00475569); // #475569
  CL_TEXT_LIGHT = TColor($0064748B); // #64748b — corrigido
  CL_MUTED      = TColor($0094A3B8); // #94a3b8
  CL_TRACK      = TColor($00F1F5F9); // #f1f5f9
  CL_FILL       = TColor($000F172A); // #0f172a
  CL_GREEN_BG   = TColor($00ECFDF5); // #ecfdf5
  CL_GREEN_FG   = TColor($00059669); // #059669
  CL_GREEN_DOT  = TColor($0010B981); // #10b981
  CL_RED        = TColor($00EF4444); // #ef4444

type
  TClassifyResult = record
    Classe:     string;
    Item:       string;
    Confianca:  Double;
    Indefinido: Boolean;
    Erro:       string;
  end;

  // ── DirectShow sample grabber callback ────────────────────────────────────
  TSampleGrabberCB = class(TInterfacedObject, ISampleGrabberCB)
  private
    FLock:          TCriticalSection;
    FBitmap:        TBitmap;
    FWidth, FHeight: Integer;
  public
    constructor Create(ALock: TCriticalSection; ABitmap: TBitmap);
    procedure SetVideoSize(W, H: Integer);
    function SampleCB(SampleTime: Double; pSample: IMediaSample): HResult; stdcall;
    function BufferCB(SampleTime: Double; pBuffer: PByte; BufferLen: Longint): HResult; stdcall;
  end;

  TFormMain = class(TForm)
    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure WMClassifyDone(var Msg: TMessage); message WM_CLASSIFY_DONE;

  private
    // ── DirectShow ───────────────────────────────────────────────────────────
    FGraph:       IGraphBuilder;
    FCapBuilder:  ICaptureGraphBuilder2;
    FMediaCtrl:   IMediaControl;
    FSGrabber:    ISampleGrabber;
    FSGFilter:    IBaseFilter;
    FNullRend:    IBaseFilter;
    FSrcFilter:   IBaseFilter;
    FGrabberCB:   TSampleGrabberCB;
    FFrameLock:   TCriticalSection;
    FFrame:       TBitmap;

    // ── UI ───────────────────────────────────────────────────────────────────
    pnlHeader:        TPanel;
    shpDot:           TShape;
    lblApiStatus:     TLabel;
    pnlCamera:        TPanel;
    imgCamera:        TImage;
    pnlSidebar:       TPanel;
    // resultado
    lblFoodName:      TLabel;
    lblItemName:      TLabel;
    lblConfValue:     TLabel;
    pnlConfTrack:     TPanel;
    pnlConfFill:      TPanel;
    // status
    pnlDetect:        TPanel;
    lblDetect:        TLabel;
    // timer
    tmrClassify:      TTimer;

    // ── estado ──────────────────────────────────────────────────────────────
    FBusy:   Boolean;
    FResult: TClassifyResult;

    procedure BuildUI;
    procedure BuildCaptureGraph;
    procedure StopCaptureGraph;
    function  CaptureBitmapAsJpeg: TBytes;
    procedure DoClassifyAsync;
    procedure tmrClassifyTimer(Sender: TObject);
    procedure ApplyResult(const R: TClassifyResult);
    procedure SetUnknownState;
    procedure SetApiStatus(Online: Boolean);
    procedure CheckApiStatus;
    function  Card(AParent: TWinControl; ALeft, ATop, AW, AH: Integer): TPanel;
    function  Lbl(AParent: TWinControl; const AText: string;
                  ASize: Integer; ABold: Boolean; AColor: TColor;
                  ALeft, ATop: Integer): TLabel;
  end;

var
  FormMain: TFormMain;

implementation

{$R *.dfm}

// =============================================================================
//  TSampleGrabberCB
// =============================================================================

constructor TSampleGrabberCB.Create(ALock: TCriticalSection; ABitmap: TBitmap);
begin
  inherited Create;
  FLock   := ALock;
  FBitmap := ABitmap;
end;

procedure TSampleGrabberCB.SetVideoSize(W, H: Integer);
begin
  FWidth := W; FHeight := H;
end;

function TSampleGrabberCB.SampleCB(SampleTime: Double; pSample: IMediaSample): HResult;
begin
  Result := S_OK;
end;

function TSampleGrabberCB.BufferCB(SampleTime: Double; pBuffer: PByte; BufferLen: Longint): HResult;
var
  Y, RowBytes: Integer;
  Dst: PByte;
begin
  Result := S_OK;
  if (FWidth = 0) or (FHeight = 0) or (pBuffer = nil) then Exit;
  RowBytes := FWidth * 3;
  FLock.Enter;
  try
    FBitmap.PixelFormat := pf24bit;
    FBitmap.Width  := FWidth;
    FBitmap.Height := FHeight;
    // DirectShow entrega RGB24 de baixo para cima
    for Y := 0 to FHeight - 1 do
    begin
      Dst := FBitmap.ScanLine[Y];
      Move(PByte(pBuffer + (FHeight - 1 - Y) * RowBytes)^, Dst^, RowBytes);
    end;
  finally
    FLock.Leave;
  end;
end;

// =============================================================================
//  TFormMain — create / destroy
// =============================================================================

procedure TFormMain.FormCreate(Sender: TObject);
begin
  FFrameLock := TCriticalSection.Create;
  FFrame     := TBitmap.Create;
  FFrame.PixelFormat := pf24bit;
  FBusy := False;

  BuildUI;
  BuildCaptureGraph;
  CheckApiStatus;

  tmrClassify.Interval := INTERVALO_MS;
  tmrClassify.Enabled  := True;
end;

procedure TFormMain.FormDestroy(Sender: TObject);
begin
  tmrClassify.Enabled := False;
  StopCaptureGraph;
  FFrame.Free;
  FFrameLock.Free;
end;

// =============================================================================
//  DIRECTSHOW
// =============================================================================

procedure TFormMain.BuildCaptureGraph;
var
  DevEnum:  ICreateDevEnum;
  EnumMon:  IEnumMoniker;
  Moniker:  IMoniker;
  Fetched:  ULONG;
  MT:       TAMMediaType;
  BV:       IBasicVideo;
  W, H:     Integer;
begin
  CoCreateInstance(CLSID_FilterGraph, nil, CLSCTX_INPROC_SERVER,
    IID_IGraphBuilder, FGraph);
  if FGraph = nil then Exit;

  CoCreateInstance(CLSID_CaptureGraphBuilder2, nil, CLSCTX_INPROC_SERVER,
    IID_ICaptureGraphBuilder2, FCapBuilder);
  FCapBuilder.SetFiltergraph(FGraph);

  // primeira câmera disponível
  CoCreateInstance(CLSID_SystemDeviceEnum, nil, CLSCTX_INPROC_SERVER,
    IID_ICreateDevEnum, DevEnum);
  DevEnum.CreateClassEnumerator(CLSID_VideoInputDeviceCategory, EnumMon, 0);
  if (EnumMon = nil) or (EnumMon.Next(1, Moniker, @Fetched) <> S_OK) then Exit;
  Moniker.BindToObject(nil, nil, IID_IBaseFilter, FSrcFilter);
  FGraph.AddFilter(FSrcFilter, 'Source');

  // sample grabber
  CoCreateInstance(CLSID_SampleGrabber, nil, CLSCTX_INPROC_SERVER,
    IID_IBaseFilter, FSGFilter);
  FGraph.AddFilter(FSGFilter, 'SampleGrabber');
  FSGFilter.QueryInterface(IID_ISampleGrabber, FSGrabber);

  FillChar(MT, SizeOf(MT), 0);
  MT.majortype := MEDIATYPE_Video;
  MT.subtype   := MEDIASUBTYPE_RGB24;
  FSGrabber.SetMediaType(MT);
  FSGrabber.SetBufferSamples(False);
  FSGrabber.SetOneShot(False);

  // null renderer (sem janela extra)
  CoCreateInstance(CLSID_NullRenderer, nil, CLSCTX_INPROC_SERVER,
    IID_IBaseFilter, FNullRend);
  FGraph.AddFilter(FNullRend, 'NullRenderer');

  FCapBuilder.RenderStream(@PIN_CATEGORY_PREVIEW, @MEDIATYPE_Video,
    FSrcFilter, FSGFilter, FNullRend);

  // tamanho real do stream
  W := 640; H := 480;
  if FSGFilter.QueryInterface(IID_IBasicVideo, BV) = S_OK then
    BV.GetVideoSize(W, H);

  FGrabberCB := TSampleGrabberCB.Create(FFrameLock, FFrame);
  FGrabberCB.SetVideoSize(W, H);
  FSGrabber.SetCallback(FGrabberCB, 1); // 1 = BufferCB

  FGraph.QueryInterface(IID_IMediaControl, FMediaCtrl);
  FMediaCtrl.Run;
end;

procedure TFormMain.StopCaptureGraph;
begin
  if Assigned(FMediaCtrl) then FMediaCtrl.Stop;
  FSGrabber := nil; FNullRend  := nil; FSGFilter  := nil;
  FSrcFilter := nil; FCapBuilder := nil; FMediaCtrl := nil;
  FGraph     := nil; FGrabberCB  := nil;
end;

// =============================================================================
//  CAPTURA → JPEG em memória
// =============================================================================

function TFormMain.CaptureBitmapAsJpeg: TBytes;
var
  Src, Flipped: TBitmap;
  Jpg: TJPEGImage;
  MS:  TMemoryStream;
  X, Y: Integer;
  SrcRow, DstRow: PByteArray;
begin
  Result := nil;
  Src := TBitmap.Create;
  try
    FFrameLock.Enter;
    try
      if FFrame.Width = 0 then Exit;
      Src.Assign(FFrame);
    finally
      FFrameLock.Leave;
    end;

    // espelho horizontal
    Flipped := TBitmap.Create;
    try
      Flipped.PixelFormat := pf24bit;
      Flipped.Width  := Src.Width;
      Flipped.Height := Src.Height;
      for Y := 0 to Src.Height - 1 do
      begin
        SrcRow := Src.ScanLine[Y];
        DstRow := Flipped.ScanLine[Y];
        for X := 0 to Src.Width - 1 do
        begin
          DstRow^[X * 3]     := SrcRow^[(Src.Width - 1 - X) * 3];
          DstRow^[X * 3 + 1] := SrcRow^[(Src.Width - 1 - X) * 3 + 1];
          DstRow^[X * 3 + 2] := SrcRow^[(Src.Width - 1 - X) * 3 + 2];
        end;
      end;

      Jpg := TJPEGImage.Create;
      MS  := TMemoryStream.Create;
      try
        Jpg.Assign(Flipped);
        Jpg.CompressionQuality := 80;
        Jpg.SaveToStream(MS);
        SetLength(Result, MS.Size);
        MS.Position := 0;
        MS.ReadBuffer(Result[0], MS.Size);
      finally
        Jpg.Free; MS.Free;
      end;
    finally
      Flipped.Free;
    end;
  finally
    Src.Free;
  end;
end;

// =============================================================================
//  TIMER + CLASSIFICAÇÃO ASYNC
// =============================================================================

procedure TFormMain.tmrClassifyTimer(Sender: TObject);
begin
  if FBusy then Exit;
  if FFrame.Width = 0 then Exit;
  FBusy := True;

  // atualiza preview
  FFrameLock.Enter;
  try
    if FFrame.Width > 0 then
      imgCamera.Picture.Assign(FFrame);
  finally
    FFrameLock.Leave;
  end;

  DoClassifyAsync;
end;

procedure TFormMain.DoClassifyAsync;
begin
  TTask.Run(
    procedure
    var
      Bytes: TBytes;
      Http:  THTTPClient;
      Form:  TMultipartFormData;
      Resp:  IHTTPResponse;
      Json:  TJSONObject;
      R:     TClassifyResult;
    begin
      FillChar(R, SizeOf(R), 0);
      try
        Bytes := CaptureBitmapAsJpeg;
        if Length(Bytes) = 0 then
        begin
          R.Erro := 'frame vazio';
        end
        else
        begin
          Http := THTTPClient.Create;
          Form := TMultipartFormData.Create;
          try
            Form.AddBytes('file', Bytes, 'frame.jpg', 'image/jpeg');
            Resp := Http.Post(API_URL + '/classify', Form);
            if Resp.StatusCode = 200 then
            begin
              Json := TJSONObject.ParseJSONValue(Resp.ContentAsString) as TJSONObject;
              if Assigned(Json) then
              try
                R.Classe     := Json.GetValue<string>('classe', '');
                R.Item       := Json.GetValue<string>('item', '');
                R.Confianca  := Json.GetValue<Double>('confianca', 0);
                R.Indefinido := Json.GetValue<Boolean>('indefinido', True);
              finally
                Json.Free;
              end;
            end
            else
              R.Erro := 'HTTP ' + Resp.StatusCode.ToString;
          finally
            Http.Free; Form.Free;
          end;
        end;
      except
        on E: Exception do R.Erro := E.Message;
      end;
      FResult := R;
      PostMessage(Handle, WM_CLASSIFY_DONE, 0, 0);
    end
  );
end;

procedure TFormMain.WMClassifyDone(var Msg: TMessage);
begin
  ApplyResult(FResult);
  FBusy := False;
end;

// =============================================================================
//  ATUALIZAÇÃO DE UI
// =============================================================================

procedure TFormMain.ApplyResult(const R: TClassifyResult);
var
  Pct: Integer;
begin
  if (R.Erro <> '') or R.Indefinido or (R.Classe = '') or (R.Confianca < 0.55) then
  begin
    SetUnknownState;
    Exit;
  end;

  lblFoodName.Caption := IfThen(R.Item <> '', R.Item, R.Classe);
  lblItemName.Caption := IfThen(R.Item <> '', '(' + R.Classe + ')', '');

  Pct := Round(R.Confianca * 100);
  lblConfValue.Caption := Pct.ToString + '%';
  pnlConfFill.Width    := Round(pnlConfTrack.Width * R.Confianca);
  pnlConfFill.Color    := CL_FILL;

  lblDetect.Caption      := 'Prato identificado  ✓';
  pnlDetect.Color        := CL_GREEN_BG;
  lblDetect.Font.Color   := CL_GREEN_FG;
end;

procedure TFormMain.SetUnknownState;
begin
  lblFoodName.Caption    := 'Nenhum prato';
  lblItemName.Caption    := '';
  lblConfValue.Caption   := '--';
  pnlConfFill.Width      := 0;
  lblDetect.Caption      := 'Aguardando detecção';
  pnlDetect.Color        := CL_TRACK;
  lblDetect.Font.Color   := CL_TEXT_MID;
end;

procedure TFormMain.SetApiStatus(Online: Boolean);
begin
  if Online then
  begin
    shpDot.Brush.Color   := CL_GREEN_DOT;
    lblApiStatus.Caption := 'Online';
    lblApiStatus.Font.Color := CL_GREEN_FG;
  end
  else
  begin
    shpDot.Brush.Color   := CL_RED;
    lblApiStatus.Caption := 'Offline';
    lblApiStatus.Font.Color := CL_RED;
  end;
end;

procedure TFormMain.CheckApiStatus;
begin
  TTask.Run(
    procedure
    var
      Http: THTTPClient;
      Ok:   Boolean;
    begin
      Ok := False;
      Http := THTTPClient.Create;
      try
        try Ok := Http.Get(API_URL + '/status').StatusCode = 200;
        except Ok := False; end;
      finally Http.Free; end;
      TThread.Queue(nil, procedure begin SetApiStatus(Ok); end);
    end
  );
end;

// =============================================================================
//  HELPERS DE UI
// =============================================================================

function TFormMain.Card(AParent: TWinControl; ALeft, ATop, AW, AH: Integer): TPanel;
begin
  Result := TPanel.Create(Self);
  Result.Parent      := AParent;
  Result.BevelOuter  := bvNone;
  Result.Color       := CL_CARD;
  Result.ParentBackground := False;
  Result.SetBounds(ALeft, ATop, AW, AH);
end;

function TFormMain.Lbl(AParent: TWinControl; const AText: string;
  ASize: Integer; ABold: Boolean; AColor: TColor; ALeft, ATop: Integer): TLabel;
begin
  Result := TLabel.Create(Self);
  Result.Parent      := AParent;
  Result.Caption     := AText;
  Result.Font.Size   := ASize;
  Result.Font.Color  := AColor;
  Result.ParentFont  := False;
  Result.AutoSize    := True;
  if ABold then Result.Font.Style := [fsBold]
  else          Result.Font.Style := [];
  Result.SetBounds(ALeft, ATop, 0, 0);
end;

// =============================================================================
//  BUILD UI  — equivalente ao layout HTML
// =============================================================================

procedure TFormMain.BuildUI;
const
  SW = 270;   // sidebar width
  G  = 10;    // gap
  P  = 14;    // padding interno dos cards
  HDR = 52;
var
  CW, CH:       Integer;
  pCard:        TPanel;
  Sep:          TBevel;
begin
  Caption      := 'Classificador de Pratos';
  ClientWidth  := 1060;
  ClientHeight := 680;
  Color        := CL_BG;
  Position     := poScreenCenter;
  Font.Name    := 'Segoe UI';

  CW := ClientWidth;
  CH := ClientHeight;

  // ══════════════════════════════════════════════════════════════════
  //  HEADER
  // ══════════════════════════════════════════════════════════════════
  pnlHeader := TPanel.Create(Self);
  pnlHeader.Parent    := Self;
  pnlHeader.Align     := alTop;
  pnlHeader.Height    := HDR;
  pnlHeader.BevelOuter:= bvNone;
  pnlHeader.Color     := clWhite;

  Lbl(pnlHeader, 'Classificador de Pratos', 10, True,  CL_TEXT_DARK,  20, 9);
  Lbl(pnlHeader, 'Identificação em tempo real', 8, False, CL_TEXT_LIGHT, 20, 27);

  shpDot := TShape.Create(Self);
  shpDot.Parent      := pnlHeader;
  shpDot.Shape       := stCircle;
  shpDot.Brush.Color := CL_GREEN_DOT;
  shpDot.Pen.Style   := psClear;
  shpDot.SetBounds(CW - 88, 22, 8, 8);
  shpDot.Anchors := [akTop, akRight];

  lblApiStatus := Lbl(pnlHeader, 'Verificando...', 8, True, CL_GREEN_FG, CW - 76, 20);
  lblApiStatus.Anchors := [akTop, akRight];

  // ══════════════════════════════════════════════════════════════════
  //  SIDEBAR (direita)
  // ══════════════════════════════════════════════════════════════════
  pnlSidebar := TPanel.Create(Self);
  pnlSidebar.Parent      := Self;
  pnlSidebar.BevelOuter  := bvNone;
  pnlSidebar.Color       := CL_BG;
  pnlSidebar.SetBounds(CW - SW - G, HDR + G, SW, CH - HDR - G * 2);
  pnlSidebar.Anchors := [akTop, akRight, akBottom];

  // ── Card Resultado ──────────────────────────────────────────────
  pCard := Card(pnlSidebar, 0, 0, SW, 148);

  Lbl(pCard, 'RESULTADO', 7, True, CL_MUTED, P, 10);

  lblFoodName := TLabel.Create(Self);
  lblFoodName.Parent    := pCard;
  lblFoodName.Caption   := 'Aguardando...';
  lblFoodName.Font.Size := 18;
  lblFoodName.Font.Style:= [fsBold];
  lblFoodName.Font.Color:= CL_TEXT_DARK;
  lblFoodName.ParentFont:= False;
  lblFoodName.WordWrap  := True;
  lblFoodName.AutoSize  := False;
  lblFoodName.SetBounds(P, 28, SW - P * 2, 46);

  lblItemName := Lbl(pCard, '', 8, False, CL_TEXT_LIGHT, P, 76);

  Lbl(pCard, 'Confiança', 8, False, CL_TEXT_LIGHT, P, 96);

  lblConfValue := Lbl(pCard, '--', 8, True, CL_TEXT_DARK, SW - 42, 96);
  lblConfValue.Anchors := [akTop, akRight];

  pnlConfTrack := TPanel.Create(Self);
  pnlConfTrack.Parent     := pCard;
  pnlConfTrack.BevelOuter := bvNone;
  pnlConfTrack.Color      := CL_TRACK;
  pnlConfTrack.SetBounds(P, 112, SW - P * 2, 6);
  pnlConfTrack.Anchors := [akLeft, akTop, akRight];

  pnlConfFill := TPanel.Create(Self);
  pnlConfFill.Parent     := pnlConfTrack;
  pnlConfFill.Align      := alLeft;
  pnlConfFill.Width      := 0;
  pnlConfFill.Height     := 6;
  pnlConfFill.BevelOuter := bvNone;
  pnlConfFill.Color      := CL_FILL;

  // ── Card Status ─────────────────────────────────────────────────
  pCard := Card(pnlSidebar, 0, 158, SW, 74);

  Lbl(pCard, 'STATUS', 7, True, CL_MUTED, P, 10);

  pnlDetect := TPanel.Create(Self);
  pnlDetect.Parent     := pCard;
  pnlDetect.BevelOuter := bvNone;
  pnlDetect.Color      := CL_TRACK;
  pnlDetect.SetBounds(P, 28, SW - P * 2, 30);

  lblDetect := TLabel.Create(Self);
  lblDetect.Parent      := pnlDetect;
  lblDetect.Caption     := 'Aguardando detecção';
  lblDetect.Font.Size   := 9;
  lblDetect.Font.Style  := [fsBold];
  lblDetect.Font.Color  := CL_TEXT_MID;
  lblDetect.ParentFont  := False;
  lblDetect.Alignment   := taCenter;
  lblDetect.AutoSize    := False;
  lblDetect.SetBounds(0, 8, SW - P * 2, 18);

  // ── Card Info ───────────────────────────────────────────────────
  pCard := Card(pnlSidebar, 0, 242, SW, 110);
  Lbl(pCard, 'INFORMAÇÕES', 7, True, CL_MUTED, P, 10);

  procedure AddRow(const L, R: string; Y: Integer);
  var
    Bv: TBevel;
  begin
    Lbl(pCard, L, 9, False, CL_TEXT_LIGHT, P, Y);
    Lbl(pCard, R, 9, True,  CL_TEXT_DARK, SW - P - 80, Y);
    if Y > 28 then
    begin
      Bv := TBevel.Create(Self);
      Bv.Parent    := pCard;
      Bv.Shape     := bsTopLine;
      Bv.SetBounds(P, Y - 4, SW - P * 2, 2);
    end;
  end;

  AddRow('API',         'localhost:8000', 30);
  AddRow('Atualização', '1.2 s',          54);
  AddRow('Modelo',      'MobileNetV2',    78);

  // ══════════════════════════════════════════════════════════════════
  //  CARD CÂMERA (esquerda)
  // ══════════════════════════════════════════════════════════════════
  pnlCamera := Card(Self, G, HDR + G, CW - SW - G * 3, CH - HDR - G * 2);
  pnlCamera.Anchors := [akLeft, akTop, akRight, akBottom];

  Lbl(pnlCamera, 'Câmera', 9, True,  CL_TEXT_DARK,  P, 10);
  Lbl(pnlCamera, 'Tempo real', 8, False, CL_MUTED, pnlCamera.Width - 80, 12);

  imgCamera := TImage.Create(Self);
  imgCamera.Parent    := pnlCamera;
  imgCamera.Align     := alClient;
  imgCamera.Stretch   := True;
  imgCamera.Center    := True;
  imgCamera.Margins.SetBounds(G, 32, G, G);
  imgCamera.AlignWithMargins := True;

  // ══════════════════════════════════════════════════════════════════
  //  TIMER
  // ══════════════════════════════════════════════════════════════════
  tmrClassify := TTimer.Create(Self);
  tmrClassify.Enabled  := False;
  tmrClassify.OnTimer  := tmrClassifyTimer;
end;

end.
