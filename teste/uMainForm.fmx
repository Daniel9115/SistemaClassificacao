object FormMain: TFormMain
Caption = 'Classificador de Pratos'
Width = 1280
Height = 720
Fill.Color = $FFF5F7FA
OnCreate = FormCreate
OnResize = FormResize

object layHeader: TLayout
Align = Top
Height = 64

```
object rectHeader: TRectangle
  Align = Client
  Fill.Color = claWhite
  Stroke.Kind = None

  object lblTitulo: TLabel
    Position.X = 24
    Position.Y = 10
    Text = 'Classificador de Pratos'
    TextSettings.Font.Size = 20
    TextSettings.Font.Style = [fsBold]
    TextSettings.FontColor = $FF191919
  end

  object lblSubtitulo: TLabel
    Position.X = 24
    Position.Y = 36
    Text = 'Identificação em tempo real'
    TextSettings.Font.Size = 12
    TextSettings.FontColor = $FF777777
  end

  object layOnline: TLayout
    Align = Right
    Width = 140
    Margins.Right = 20

    object rectOnline: TRectangle
      Position.X = 0
      Position.Y = 14
      Width = 110
      Height = 34
      XRadius = 16
      YRadius = 16
      Fill.Color = $FFE8F5E9
      Stroke.Kind = None

      object cirOnline: TCircle
        Position.X = 12
        Position.Y = 11
        Width = 12
        Height = 12
        Fill.Color = claLimegreen
        Stroke.Kind = None
      end

      object lblOnline: TLabel
        Position.X = 32
        Position.Y = 8
        Text = 'Online'
        TextSettings.Font.Size = 12
        TextSettings.Font.Style = [fsBold]
        TextSettings.FontColor = claGreen
      end
    end
  end
end
```

end

object layContent: TLayout
